NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# Meta App ID — only needed to set the business profile photo (Settings → Business Profile)
WHATSAPP_APP_ID=
WHATSAPP_BROADCAST_TEMPLATE_NAME=ceo_template
WHATSAPP_BROADCAST_TEMPLATE_LANGUAGE=en
WHATSAPP_MORNING_TEMPLATE_BODY=
WHATSAPP_TEST_ALLOWLIST_E164=

CRON_JOB_SECRET=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Optional: Google reverse geocoding for location-pin replies (falls back to free OpenStreetMap if unset)
GOOGLE_MAPS_API_KEY=

# Voice-note transcription. gpt-4o-transcribe accepts language=bn and is far more accurate for Bengali than whisper-1.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TRANSCRIBE_LANGUAGE=bn

NEXT_PUBLIC_APP_TIMEZONE=Asia/Dhaka
NEXT_PUBLIC_ENABLE_TEST_SCHEDULER=false

ADMIN_LOGIN_USERNAME=admin
ADMIN_LOGIN_PASSWORD=
# Optional secure mode (preferred): set these and leave ADMIN_LOGIN_PASSWORD empty
# ADMIN_PASSWORD_SALT=
# ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# Legacy fallback password (optional)
CEO_PANEL_PASSWORD=

REPORT_BRAND_NAME=Champions Family
REPORT_BRAND_TAGLINE=Operational Messaging Intelligence
